	mfmsr     %r7
	li        %r8, 16
	andc      %r8, %r7, %r8
	li        %r5, 512
	oris      %r5, %r5, 32768
	sldi      %r5, %r5, 32
	oris      %r5, %r5, 51211
	ori       %r5, %r5, 32768
	loadPatchSet:
	mtmsrd    %r8, 0
	isync
	lwz       %r4, 0(%r5)
	lwz       %r3, 4(%r5)
	addi      %r5, %r5, 8
	cmpwi     cr6, %r4, -1
	beq       cr6, endPatches
	mtspr     %CTR, %r3
	loadPatches:
	mtmsrd    %r8, 0
	isync
	lwz      %r3, 0(%r5)
	mtmsrd    %r7, 0
	isync
	stw      %r3, 0(%r4)
	dcbst     %r0, %r4
	icbi      %r0, %r4
	sync
	isync
	addi      %r4, %r4, 4
	addi      %r5, %r5, 4
	bdnz      loadPatches
	b         loadPatchSet
	endPatches:
	lis       %r3, 40
[!ASM]

